{
  "rotationDuration": 5000,
  "transitionAnimation": "fadeSlide",
  "colors": {
    "panelBackground": "#F3F3F3",
    "panelBorder": "#002740",
    "primaryText": "#002740",
    "secondaryText": "#666666",
    "progressBarBackground": "#E0E0E0",
    "progressBarFill": "#002740",
    "progressBarFillEnd": "#004d73",
    "accentColor": "#9146ff"
  },
  "youtube": {
    "apiKey": "",
    "channelId": ""
  },
  "elements": [
    {
      "id": "followerGoal",
      "type": "progress",
      "enabled": true,
      "title": "Follower Goal",
      "emote": "👥",
      "zIndex": 1,
      "animation": "fadeIn",
      "dataSource": "twitch.followers",
      "fields": {
        "goal": 200,
        "current": 0,
        "showPercentage": true,
        "subtext": ""
      }
    },
    {
      "id": "subscriberGoal",
      "type": "progress",
      "enabled": true,
      "title": "Subscriber Goal",
      "emote": "⭐",
      "zIndex": 2,
      "animation": "slideLeft",
      "dataSource": "twitch.subscribers",
      "fields": {
        "goal": 500,
        "current": 0,
        "showPercentage": true,
        "subtext": ""
      }
    },
    {
      "id": "donations",
      "type": "counter",
      "enabled": true,
      "title": "Total Donations",
      "emote": "💰",
      "zIndex": 3,
      "animation": "slideUp",
      "dataSource": "custom.donations",
      "fields": {
        "value": 0,
        "prefix": "$",
        "suffix": "",
        "subtext": "Thank you for your support!"
      }
    },
    {
      "id": "discord",
      "type": "info",
      "enabled": true,
      "title": "!discord",
      "emote": "📋",
      "zIndex": 4,
      "animation": "fadeIn",
      "dataSource": "none",
      "fields": {
        "text": "Join our Community on Discord!",
        "subtext": "Use this command in chat to get the link",
        "showThumbnail": false
      }
    },
    {
      "id": "latestVideo",
      "type": "info",
      "enabled": true,
      "title": "Latest YouTube Video",
      "emote": "🎬",
      "zIndex": 5,
      "animation": "scale",
      "dataSource": "youtube.latestVideo",
      "fields": {
        "showThumbnail": true,
        "text": "Latest YouTube Video",
        "subtext": "Type !youtube in chat"
      }
    }
  ]
}